{% import 'components/form/fields_macros.html.twig' as fields %}

<div class="card col-12 col-lg-8 mx-auto my-4">
    <div class="card-header">
        <h3 class="card-title">{{ __('Google SSO — Configuration', 'googlesso') }}</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            {{ __('Register this Redirect URI in Google Cloud Console:', 'googlesso') }}
            <code>{{ redirect_uri }}</code>
        </div>

        <form method="post" action="{{ action }}">
            <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

            <div class="mb-3">
                <label class="form-label" for="client_id">Client ID</label>
                <input type="text" class="form-control" id="client_id" name="client_id"
                       value="{{ config.client_id }}" placeholder="[GOOGLE_CLIENT_ID]">
            </div>

            <div class="mb-3">
                <label class="form-label" for="client_secret">Client Secret</label>
                <input type="password" class="form-control" id="client_secret" name="client_secret"
                       value="" autocomplete="new-password"
                       placeholder="{{ config.client_secret ? '••••••••••' : '[GOOGLE_CLIENT_SECRET]' }}">
                <small class="form-hint">{{ __('Leave blank to keep current secret (stored encrypted).', 'googlesso') }}</small>
            </div>

            <div class="mb-3">
                <label class="form-label" for="restrict_domain">{{ __('Restrict to domain (optional)', 'googlesso') }}</label>
                <input type="text" class="form-control" id="restrict_domain" name="restrict_domain"
                       value="{{ config.restrict_domain }}" placeholder="empresa.com.br">
            </div>

            <div class="mb-3">
                <label class="form-check form-switch">
                    <input type="hidden" name="auto_create_users" value="0">
                    <input class="form-check-input" type="checkbox" name="auto_create_users" value="1"
                           {{ config.auto_create_users ? 'checked' : '' }}>
                    <span class="form-check-label">{{ __('Automatically create users on first login', 'googlesso') }}</span>
                </label>
            </div>

            <hr class="my-4">
            <h4>{{ __('Profile and Entity Rules by Domain', 'googlesso') }}</h4>
            <div class="alert alert-secondary">
                {{ __('Add rules to define which profile and entity the user will receive based on their email domain (Optional).', 'googlesso') }}
            </div>
            
            <table class="table table-sm table-bordered" id="domain-rules-table">
                <thead>
                    <tr>
                        <th>{{ __('Domain (after @)', 'googlesso') }}</th>
                        <th>{{ __('Profile', 'googlesso') }}</th>
                        <th>{{ __('Entity', 'googlesso') }}</th>
                        <th style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for rule in config.domain_rules %}
                        <tr>
                            <td>
                                <input type="text" name="domain_rule_domain[]" class="form-control" value="{{ rule.domain }}" required>
                            </td>
                            <td>
                                <select name="domain_rule_profile_id[]" class="form-select" required>
                                    <option value="">{{ __('Select...', 'googlesso') }}</option>
                                    {% for id, name in profiles %}
                                        <option value="{{ id }}" {{ id == rule.profile_id ? 'selected' : '' }}>{{ name }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <select name="domain_rule_entity_id[]" class="form-select" required>
                                    <option value="">{{ __('Select...', 'googlesso') }}</option>
                                    {% for id, name in entities %}
                                        <option value="{{ id }}" {{ id == rule.entity_id ? 'selected' : '' }}>{{ name }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-icon btn-danger btn-sm btn-remove-rule"><i class="ti ti-trash"></i></button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <button type="button" class="btn btn-outline-primary btn-sm mb-4" id="btn-add-rule">
                <i class="ti ti-plus me-1"></i> {{ __('Add Rule', 'googlesso') }}
            </button>

            <table style="display:none;">
                <tbody id="rule-template">
                    <tr>
                        <td>
                            <input type="text" name="domain_rule_domain[]" class="form-control" placeholder="ex: aluno.edu.br" required disabled>
                        </td>
                        <td>
                            <select name="domain_rule_profile_id[]" class="form-select" required disabled>
                                <option value="">{{ __('Select...', 'googlesso') }}</option>
                                {% for id, name in profiles %}
                                    <option value="{{ id }}">{{ name }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td>
                            <select name="domain_rule_entity_id[]" class="form-select" required disabled>
                                <option value="">{{ __('Select...', 'googlesso') }}</option>
                                {% for id, name in entities %}
                                    <option value="{{ id }}">{{ name }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-icon btn-danger btn-sm btn-remove-rule"><i class="ti ti-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>

            <hr class="my-4">
            <h4>{{ __('Default Rule (Fallback)', 'googlesso') }}</h4>
            <div class="alert alert-secondary">
                {{ __('If the user email does not match any of the rules above, this profile and entity will be used. Mandatory if automatic creation is enabled.', 'googlesso') }}
            </div>

            {{ fields.dropdownField('Profile', 'default_profile_id', config.default_profile_id,
                __('Default profile (ELSE)', 'googlesso')) }}

            {{ fields.dropdownField('Entity', 'default_entity_id', config.default_entity_id,
                __('Default entity (ELSE)', 'googlesso')) }}

            <div class="mt-4 text-end">
                <button type="submit" name="update" value="1" class="btn btn-primary">
                    <i class="ti ti-device-floppy me-1"></i>{{ __('Salvar') }}
                </button>
            </div>
        </form>
    </div>
</div>

<script>
$(function() {
    $('#btn-add-rule').on('click', function() {
        var $newRow = $('#rule-template tr').clone();
        $newRow.find(':input').prop('disabled', false);
        $('#domain-rules-table tbody').append($newRow);
    });

    $('#domain-rules-table').on('click', '.btn-remove-rule', function() {
        $(this).closest('tr').remove();
    });
});
</script>
